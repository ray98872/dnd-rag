# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Vector Store ──────────────────────────────────────────────────────────────
# Local Docker (default) — no key needed
QDRANT_URL=http://localhost:6333
# Qdrant Cloud free tier — set both of these instead
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key

QDRANT_COLLECTION=dnd_srd

# ── Embeddings (local, no key needed) ─────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# ── RAG Tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=10
RERANK_TOP_N=4

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Observability (optional) ──────────────────────────────────────────────────
# Get a free key at: https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=dnd-rag

# ── Azure OpenAI (optional swap — leave blank to use Groq + local embeddings) ─
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-01
